# Qt project gitattributes
# Ensures consistent line endings

# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized
*.cpp text
*.h text
*.hpp text
*.c text
*.ui text
*.pro text
*.qrc text
*.md text
*.txt text

# Binary files
*.exe binary
*.dll binary
*.so binary
*.o binary
*.obj binary
*.a binary
*.lib binary
*.db binary
*.sqlite binary
